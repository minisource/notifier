  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Notifier Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Launch Migration Up",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/migrate",
      "args": ["up"],
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
