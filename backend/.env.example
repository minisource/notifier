# ===========================================
# Notifier Service - Environment Configuration
# ===========================================
# Copy this file to .env and fill in values
# cp .env.example .env

# -------------------------------------------
# Docker Compose
# -------------------------------------------
COMPOSE_PROJECT_NAME=notifier

# -------------------------------------------
# Server
# -------------------------------------------
SERVER_INTERNAL_PORT=9002
SERVER_EXTERNAL_PORT=9002
SERVER_RUN_MODE=development
SERVER_NAME=Notifier

# -------------------------------------------
# PostgreSQL
# -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DBNAME=notifier_db
POSTGRES_DB=notifier_db
POSTGRES_SSLMODE=disable
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_OPEN_CONNS=100
POSTGRES_CONN_MAX_LIFETIME=60

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_PORT=6381
REDIS_PASSWORD=

# -------------------------------------------
# Worker
# -------------------------------------------
WORKER_NUM_WORKERS=10
WORKER_QUEUE_SIZE=1000
WORKER_RETRY_MAX_DELAY=300
WORKER_RETRY_BASE_DELAY=5

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PROVIDER_TEST_REQUESTS=10
RATE_LIMIT_NOTIFICATION_CREATE_REQUESTS=30

# -------------------------------------------
# CORS
# -------------------------------------------
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-Id,X-Tenant-Id
CORS_ALLOW_CREDENTIALS=false

# -------------------------------------------
# Logger
# -------------------------------------------
LOGGER_FILE_PATH=logs/notifier.log
LOGGER_ENCODING=json
LOGGER_LEVEL=info
LOGGER_TYPE=zap
LOGGER_CONSOLE_ONLY=false

# -------------------------------------------
# gRPC
# -------------------------------------------
GRPC_PORT=9003
GRPC_ENABLED=true

# -------------------------------------------
# Auth
# -------------------------------------------
AUTH_ENABLED=true
AUTH_BASE_URL=http://localhost:9001
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_JWT_SECRET=

# -------------------------------------------
# Database
# -------------------------------------------
# SQL migrations are the source of truth for schema.
# GORM AutoMigrate should only be enabled for local development.
# SQL migrations are the source of truth for schema.
# GORM AutoMigrate controlled by DB_RUN_MIGRATIONS (below).
DB_RUN_MIGRATIONS=false
DB_RUN_SEED_DATA=false

# -------------------------------------------
# Kavenegar (SMS)
# -------------------------------------------
KAVENEGAR_ENABLED=false
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=verify

# -------------------------------------------
# Tracing (Jaeger)
# -------------------------------------------
TRACING_ENABLED=false
JAEGER_URL=http://localhost:14268/api/traces
TRACING_SERVICE_NAME=notifier-service

# -------------------------------------------
# Override (optional)
# -------------------------------------------
PORT=9002
