# ===========================================
# Notifier Admin Frontend - Environment Variables
# ===========================================

# ========== Application ==========
NEXT_PUBLIC_APP_NAME=Notifier Admin
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_DEFAULT_LOCALE=fa

# ========== API Mode ==========
# mock = offline development without backend
# real = connect to actual notifier backend
NEXT_PUBLIC_API_MODE=mock

# ========== Backend API ==========
NEXT_PUBLIC_NOTIFIER_API_URL=http://localhost:9002/v1

# ========== Mock Data (API responses) ==========
# Controls whether mock data is served INSTEAD of real API calls.
# Must be explicitly set to true to use mock data.
# Default when unset/empty: false
# This is INDEPENDENT of mock auth below.
NEXT_PUBLIC_NOTIFIER_USE_MOCKS=false

# ========== Mock Auth / Session (temporary) ==========
# These provide session context until the real Auth service is integrated.
# They can be enabled while NEXT_PUBLIC_NOTIFIER_USE_MOCKS=false,
# meaning: use mock session tokens but call real backend APIs.
#
# IMPORTANT: Tenant/Project IDs are NOT hardcoded defaults.
# If left empty, X-Tenant-Id and X-Project-Id headers are NOT sent.
# Configure a valid tenant ID that your backend accepts, or enable
# the backend's dev default-tenant mode.
NEXT_PUBLIC_NOTIFIER_MOCK_AUTH_ENABLED=true
NEXT_PUBLIC_NOTIFIER_MOCK_ACCESS_TOKEN=mock-token-notifier-admin
NEXT_PUBLIC_NOTIFIER_MOCK_USER_ID=user-mock-001
# Leave empty if backend does not require tenant, or set to a backend-accepted tenant ID.
NEXT_PUBLIC_NOTIFIER_MOCK_TENANT_ID=
# Optional: leave empty if not needed.
NEXT_PUBLIC_NOTIFIER_MOCK_PROJECT_ID=
NEXT_PUBLIC_NOTIFIER_MOCK_ROLES=admin,operator

# ========== Realtime / Polling ==========
NEXT_PUBLIC_NOTIFIER_REALTIME_MODE=polling
NEXT_PUBLIC_NOTIFIER_REALTIME_URL=
NEXT_PUBLIC_NOTIFIER_REALTIME_POLL_INTERVAL=30000

# ========== Live Toasts ==========
NEXT_PUBLIC_NOTIFIER_SHOW_LIVE_TOASTS=true
